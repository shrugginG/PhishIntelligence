# ─── Supabase ───
# MUST be a pooler URL (not direct db.<ref>.supabase.co — IPv6-only, NAS has
# no public v6).
#
#   self-hosted NAS:   postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres
#   cloud session:     postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres

# ─── VirusTotal API key ───
# Header `x-apikey` (NOT a Bearer token despite what some docs imply).
# Academic January tier: 20,000 req/day per user. Steady-state usage is
# ~12k/day (4k URL/day × 3 calls/scan), so we sit at ~60% of quota.
VIRUSTOTAL_ACADEMIC_API_KEY=<vt-key-64-hex>

# ─── Optional tunables (defaults shown; uncomment to override) ───
# PHASE_1_LIMIT=200            # max submitted rows polled per tick
# PHASE_2_LIMIT=200            # max pending rows POSTed per tick
# CONCURRENCY=10               # asyncio.Semaphore size
# HARD_BUDGET_SEC=720          # 12 min internal tick deadline (cron is 30 min)
# SUBMITTED_TIMEOUT_SEC=7200   # 2h: rows submitted longer than this get re-POSTed
# MAX_ATTEMPTS=3               # rows with >= 3 failures stay 'failed'
# QUOTA_ABORT_RATIO=0.95       # if VT user daily quota > this, exit early
# HTTP_TIMEOUT_SEC=20
# HTTP_CONNECT_TIMEOUT=10
