# ─── Supabase ───
# MUST be a pooler URL (not direct db.<ref>.supabase.co — that's IPv6-only,
# the NAS has no public v6).
#
#   self-hosted NAS:   postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres
#   cloud session:     postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres

# ─── PhishTank (used by `run.sh phishtank` and `run.sh bootstrap`) ───
# API key embedded in URL path. Bulk dump endpoint.
PHISHTANK_TOKEN=<api-key>

# ─── eCrimeX (APWG) (used by `run.sh ecrimex` and `run.sh bootstrap`) ───
# Bearer token.
ECRIMEX_TOKEN=<bearer-token>

# ─── OpenPhish Academic (used by `run.sh openphish_academic` and `run.sh bootstrap`) ───
# HTTPS Basic Auth against the private GitHub repo `openphish/academic`.
# PAT expires 60 days from approval; renew via GitHub if cloning starts failing.
OPENPHISH_GITHUB_USER=<gh-user>
OPENPHISH_GITHUB_PAT=<gh-pat>

# ─── OpenPhish Community / PhishStats: no credentials needed ───

# Note: VirusTotal and urlscan credentials are intentionally NOT here — those
# fetchers run in their own dedicated containers (phishing_virustotal_fetcher /
# phishing_urlscan_fetcher) with their own .env files.
