# ─── urlscan API key pool (comma-separated, 1+) ───
# Round-robin across these keys multiplies effective daily quota.
# Free academic tier: 5000 public scans/day per key.
URLSCAN_API_KEYS=key1,key2

# ─── Supabase DB (psycopg connection) ───
# MUST be a pooler URL (not direct db.<ref>.supabase.co — IPv6-only, NAS has
# no public v6).
#
#   self-hosted NAS:   postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres
#   cloud session:     postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-tenant-id:<pwd>@192.168.1.161:54322/postgres

# ─── Supabase Storage (HTTP API for the 4-pack: result/screenshot/dom/meta) ───
# Base URL = Kong gateway (8000 on self-hosted NAS, or https://<project>.supabase.co
# for cloud). Service role key required for write access into the private
# `phishing-urlscan-results` bucket. NEVER expose this in client/frontend code.
SUPABASE_URL=http://192.168.1.161:8000
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-or-sb_secret_...>

# ─── Optional fetcher tunables (defaults shown; uncomment to override) ───
# PHASE_1_LIMIT=200                          # max submitted rows polled per tick
# PHASE_2_LIMIT=100                          # max pending rows POSTed per tick
# CONCURRENCY=5                              # asyncio.Semaphore size
# HARD_BUDGET_SEC=720                        # 12 min hard tick deadline (cron is every 15)
# SUBMITTED_TIMEOUT_SEC=7200                 # 2h: submitted rows older than this re-POST
# MAX_ATTEMPTS=3                             # rows with >= 3 failures stay 'failed'
# QUOTA_ABORT_RATIO=0.95                     # if pool combined daily usage > this, exit early
# HTTP_TIMEOUT_SEC=30
# HTTP_CONNECT_TIMEOUT=10
# STORAGE_BUCKET=phishing-urlscan-results    # only override if you renamed the bucket
