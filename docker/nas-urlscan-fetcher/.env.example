# ─── urlscan API key pool (comma-separated, 1+) ───
# Round-robin selection across these keys multiplies effective daily quota.
# Each key has 5000 public scans/day on the free academic tier.
URLSCAN_API_KEYS=key1,key2

# ─── Supabase ───
# MUST use Session Pooler URL (port 5432, host pooler.supabase.com) — IPv4.
# Direct db.<ref>.supabase.co is IPv6-only and the NAS has no public v6.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── fetcher tunables (defaults shown; uncomment to override) ───
# URLSCAN_DATA_ROOT=/data           # path inside container (bind-mounted from host)
# PHASE_1_LIMIT=200                 # max submitted rows polled per tick
# PHASE_2_LIMIT=100                 # max pending rows POSTed per tick
# CONCURRENCY=5                     # asyncio.Semaphore size
# HARD_BUDGET_SEC=720               # 12 min hard tick deadline (cron is every 15)
# SUBMITTED_TIMEOUT_SEC=7200        # 2h: submitted rows older than this re-POST
# MAX_ATTEMPTS=3                    # rows with >= 3 failures stay 'failed'
# QUOTA_ABORT_RATIO=0.95            # if pool combined daily usage > this, exit early
# HTTP_TIMEOUT_SEC=30
# HTTP_CONNECT_TIMEOUT=10
