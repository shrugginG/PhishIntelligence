# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. CI uses GitHub Secrets directly.

# Supabase Postgres connection string
# Find at Supabase Dashboard → Project Settings → Database → Connection pooling → "Session" mode
#
# IMPORTANT: Free tier direct connection (db.<ref>.supabase.co:5432) is IPv6-only.
# GitHub Actions runners and most home/office networks are IPv4-only — direct
# connection will fail with "Network is unreachable".
# → Use the Session Pooler URL instead (IPv4 compatible, free, no functional limits).
#
# Session Pooler format (note: username is "postgres.<project-ref>", host is the
# pooler endpoint, port stays 5432):
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Source credentials (only needed for fetcher scripts, not reset)
PHISHTANK_TOKEN=
ECRIMEX_TOKEN=
OPENPHISH_GITHUB_USER=
OPENPHISH_GITHUB_PAT=
