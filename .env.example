# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. CI uses GitHub Secrets directly.

# Supabase Postgres connection string
# Find at Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" / "psql" format (not the "postgres://" pooler URL unless you need PgBouncer)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Source credentials (only needed for fetcher scripts, not reset)
PHISHTANK_TOKEN=
ECRIMEX_TOKEN=
OPENPHISH_GITHUB_USER=
OPENPHISH_GITHUB_PAT=
